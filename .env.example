# =============================================================
# Корневой .env — используется Docker Compose
# Скопируй в .env и заполни своими значениями
# =============================================================

# --- PostgreSQL (для Docker Compose) ---
POSTGRES_USER=findme_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=findme_db

# --- Backend ---
PORT=3000
# В Docker: хост = postgres (имя сервиса). Локально: localhost
DATABASE_URL="postgresql://findme_user:change_me@postgres:5432/findme_db"

# --- Redis ---
# Локально: localhost | В Docker: redis
REDIS_HOST=redis
REDIS_PORT=6379

# --- JWT (сгенерируй случайные строки) ---
JWT_ACCESS_SECRET=replace_with_random_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_another_random_secret_min_32_chars

# --- URLs ---
CLIENT_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:3000

# --- Mail (опционально; если пусто — письма выводятся в логи) ---
MAIL_FROM=noreply@findme.local
MAIL_BRAND_NAME=FindMe
MAIL_LOGO_URL=
MAIL_API_URL=
MAIL_API_KEY=

# Gmail App Password (см. GMAIL_SETUP.md)
GMAIL_USER=
GMAIL_PASSWORD=

# --- Google OAuth (опционально; см. GOOGLE_AUTH_SETUP.md) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Telegram Bot (опционально) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CHANNEL_URL=
