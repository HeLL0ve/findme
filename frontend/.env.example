# =============================================================
# frontend/.env — опционально, только если нужно переопределить URL API
# По умолчанию фронт обращается к http://localhost:3000
# =============================================================

# URL бэкенда (нужен только если бэкенд не на localhost:3000)
VITE_API_URL=http://localhost:3000

# WebSocket URL (если не указан — вычисляется автоматически из VITE_API_URL)
# VITE_WS_URL=ws://localhost:3000/ws
