# =============================================================
# backend/.env — используется при локальном запуске (без Docker)
# Скопируй в backend/.env и заполни своими значениями
# =============================================================

PORT=3000

# Подключение к PostgreSQL (запущенному локально или через docker-compose up postgres)
DATABASE_URL="postgresql://findme_user:change_me@localhost:5432/findme_db"

# Redis (локально всегда localhost)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (сгенерируй случайные строки)
JWT_ACCESS_SECRET=replace_with_random_secret_min_32_chars
JWT_REFRESH_SECRET=replace_with_another_random_secret_min_32_chars

# URLs
CLIENT_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:3000

# Mail (опционально; если пусто — письма выводятся в логи)
MAIL_FROM=noreply@findme.local
MAIL_BRAND_NAME=FindMe
MAIL_LOGO_URL=
MAIL_API_URL=
MAIL_API_KEY=

# Gmail App Password (см. GMAIL_SETUP.md)
GMAIL_USER=
GMAIL_PASSWORD=

# Google OAuth (опционально; см. GOOGLE_AUTH_SETUP.md)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Telegram Bot (опционально)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CHANNEL_URL=
